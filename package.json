{
  "name": "wc-schedule",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:manual": "VITE_DATA_SOURCE=manual vite",
    "dev:remote": "VITE_DATA_SOURCE=remote vite",
    "build": "vue-tsc -b && vite build",
    "build:manual": "VITE_DATA_SOURCE=manual vue-tsc -b && vite build",
    "build:remote": "VITE_DATA_SOURCE=remote vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "flags:sync": "node scripts/sync-flags.mjs",
    "generate:icons": "pwa-assets-generator",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^24.12.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "circle-flags": "^2.8.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^16.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{ts,vue,css}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
